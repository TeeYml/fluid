{
  "name": "fluid-server-ts",
  "version": "0.1.0",
  "description": "Fluid - Stellar fee sponsorship server (TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run native:build && tsc",
    "build:ts": "tsc",
    "native:build": "napi build --release",
    "native:build:debug": "napi build",
    "benchmark:signing": "npm run native:build && ts-node src/benchmarks/signing.ts",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch"
  },
  "napi": {
    "name": "fluid_signer"
  },
  "keywords": [
    "stellar",
    "fee-bump",
    "gas-sponsorship"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "@stellar/stellar-sdk": "^11.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.37",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
